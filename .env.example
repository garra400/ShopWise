# Spoonacular Food API — free-tier key from https://spoonacular.com/food-api
# Without this key the app uses the built-in local recipe database.
# Copy this file to .env and paste your key to enable live recipe search.
EXPO_PUBLIC_SPOONACULAR_API_KEY=

# ---------------------------------------------------------------------------
# Supabase — optional cloud sync (local-first: app works without these keys)
# ---------------------------------------------------------------------------
# 1. Create a FREE project at https://supabase.com (no credit card required).
# 2. In the Supabase SQL editor, run supabase_schema.sql (project root).
# 3. Go to Project Settings → API, copy the Project URL and anon/public key.
# 4. Paste them below and restart the Expo dev server.
# Without these keys the app stays 100% local with zero network calls.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
